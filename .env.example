# Database. Use a pooled URL at runtime and a direct URL for migrations when available.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/whatsapp_ai_assistant?schema=public"
DATABASE_POOL_MAX="5"
DATABASE_CONNECTION_TIMEOUT_MS="15000"
DATABASE_READ_RETRY_MAX_ATTEMPTS="3"
DATABASE_READ_RETRY_BASE_DELAY_MS="100"
DATABASE_READ_RETRY_MAX_DELAY_MS="800"
DATABASE_IDLE_TIMEOUT_MS="10000"

# Application security. AUTH_SECRET and WIDGET_SIGNING_SECRET must be random and
# at least 32 bytes. DATA_ENCRYPTION_KEY must decode to exactly 32 bytes.
AUTH_SECRET="replace-with-at-least-32-random-bytes"
WIDGET_SIGNING_SECRET="replace-with-a-different-32-byte-random-string"
DATA_ENCRYPTION_KEY="replace-with-32-random-bytes-as-base64url-or-64-hex-characters"
CRON_SECRET="replace-with-at-least-32-random-bytes"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Keep disabled until active-workspace selection and core-loader RBAC are ready.
TEAM_MANAGEMENT_ENABLED="false"

# Public beta registration is enabled by default so /signup works immediately.
# Set this to false to return to invite-only mode. SIGNUP_GUARD_SECRET is
# optional; AUTH_SECRET is used as its HMAC key when omitted.
PUBLIC_SIGNUP_ENABLED="true"
SIGNUP_GUARD_SECRET=""

# Transactional email is required for public signup, email verification, and
# password recovery. EMAIL_FROM must use a sender/domain verified in Resend.
RESEND_API_KEY=""
EMAIL_FROM="Aijou AI <noreply@example.com>"

# Optional tenant-wide widget capacity. Defaults are deliberately generous and
# can be raised for campaigns without changing application code.
WIDGET_INIT_WORKSPACE_PER_MINUTE="5000"
WIDGET_INIT_WORKSPACE_PER_HOUR="100000"
WEB_CHAT_WORKSPACE_PER_MINUTE="2000"
WEB_CHAT_WORKSPACE_PER_HOUR="100000"
WEB_BRIEF_WORKSPACE_PER_MINUTE="600"
WEB_BRIEF_WORKSPACE_PER_HOUR="20000"

# Initial owner bootstrap. Existing workspace content is preserved unless the
# explicit refresh flag is enabled.
SEED_OWNER_NAME="Owner"
SEED_OWNER_EMAIL="owner@example.com"
SEED_OWNER_PASSWORD="change-me-now"
SEED_ROTATE_OWNER_PASSWORD="false"
SEED_REFRESH_DEMO_DATA="false"
SEED_BUSINESS_NAME="IT Consultant"

# AI text and receipt vision.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"
GROQ_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# Persistent private receipt media in production.
BLOB_READ_WRITE_TOKEN=""

# WhatsApp Cloud API. These may also be configured per workspace in the app.
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_GRAPH_API_VERSION="v21.0"
WHATSAPP_GRAPH_API_BASE_URL="https://graph.facebook.com"
WHATSAPP_GRAPH_TIMEOUT_MS="10000"
WHATSAPP_MAX_MEDIA_BYTES="10485760"
WHATSAPP_DEFAULT_COUNTRY_CODE="62"

# Telegram bot token is configured per workspace in the app. Only the shared
# provider request timeout belongs in environment configuration.
TELEGRAM_API_TIMEOUT_MS="10000"

# Xendit is configured per workspace from /payments. Do not put tenant
# credentials in shared environment variables.
