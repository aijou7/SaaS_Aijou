# Database. Use a pooled URL at runtime and a direct URL for migrations when available.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/whatsapp_ai_assistant?schema=public"
DATABASE_POOL_MAX="5"
DATABASE_CONNECTION_TIMEOUT_MS="5000"
DATABASE_IDLE_TIMEOUT_MS="10000"

# Application security. AUTH_SECRET and WIDGET_SIGNING_SECRET must be random and
# at least 32 bytes. DATA_ENCRYPTION_KEY must decode to exactly 32 bytes.
AUTH_SECRET="replace-with-at-least-32-random-bytes"
WIDGET_SIGNING_SECRET="replace-with-a-different-32-byte-random-string"
DATA_ENCRYPTION_KEY="replace-with-32-random-bytes-as-base64url-or-64-hex-characters"
CRON_SECRET="replace-with-at-least-32-random-bytes"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Initial owner bootstrap. Existing workspace content is preserved unless the
# explicit refresh flag is enabled.
SEED_OWNER_NAME="Owner"
SEED_OWNER_EMAIL="owner@example.com"
SEED_OWNER_PASSWORD="change-me-now"
SEED_ROTATE_OWNER_PASSWORD="false"
SEED_REFRESH_DEMO_DATA="false"
SEED_BUSINESS_NAME="IT Consultant"

# AI text and receipt vision.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"
GROQ_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# Persistent private receipt media in production.
BLOB_READ_WRITE_TOKEN=""

# WhatsApp Cloud API. These may also be configured per workspace in the app.
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_GRAPH_API_VERSION="v21.0"
WHATSAPP_GRAPH_API_BASE_URL="https://graph.facebook.com"
WHATSAPP_GRAPH_TIMEOUT_MS="10000"
WHATSAPP_MAX_MEDIA_BYTES="10485760"
WHATSAPP_DEFAULT_COUNTRY_CODE="62"

# Xendit is configured per workspace from /payments. Do not put tenant
# credentials in shared environment variables.
